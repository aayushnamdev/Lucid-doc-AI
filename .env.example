# ── Provider ─────────────────────────────────────────────────────────────────
# Pick one: anthropic | openai | xai
LUCID_PROVIDER=anthropic

# ── Model ────────────────────────────────────────────────────────────────────
# Anthropic options   : claude-haiku-4-5 (default, cheap) | claude-sonnet-4-6
# OpenAI options      : gpt-5.4-nano | gpt-5.4-mini | gpt-5.4
# xAI options         : grok-4-1-fast (cheapest) | grok-4.3
# Verify exact IDs at: docs.anthropic.com | platform.openai.com | docs.x.ai
LUCID_MODEL=claude-haiku-4-5

# ── Audience ──────────────────────────────────────────────────────────────────
# Controls language and depth of generated docs
# Options: developer | manager | non-technical | end-user
LUCID_AUDIENCE=developer

# ── Pitch model override (Phase 3) ───────────────────────────────────────────
# Pitch+Flow synthesis uses this stronger model for one call per repo.
# If unset, falls back to LUCID_MODEL. Recommended: gpt-5.4-mini.
LUCID_PITCH_MODEL=gpt-5.4-mini

# ── API Keys (fill whichever provider(s) you have) ───────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
